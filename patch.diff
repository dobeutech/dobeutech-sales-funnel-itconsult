      - name: Delete colliding preview branch and prune if needed
        env:
          NEON_API_KEY: ${{ secrets.NEON_API_KEY }}
          NEON_PROJECT_ID: ${{ vars.NEON_PROJECT_ID }}
        run: |
          npm i -g neonctl@v2
          echo "Deleting current preview branch if it already exists to prevent 422 errors"
          neonctl branches delete ${{ env.TRUNC_BRANCH }} --project-id $NEON_PROJECT_ID || true

          echo "Checking branch count to avoid 10-branch limit on free tier"
          BRANCH_COUNT=$(neonctl branches list --project-id $NEON_PROJECT_ID --output json | jq '. | length')
          if [ "$BRANCH_COUNT" -ge 10 ]; then
            OLDEST_BRANCH=$(neonctl branches list --project-id $NEON_PROJECT_ID --output json | jq -r '[.[] | select(.name | startswith("preview/pr-"))] | sort_by(.created_at) | .[0].name')
            if [ -n "$OLDEST_BRANCH" ] && [ "$OLDEST_BRANCH" != "null" ]; then
              echo "Limit reached ($BRANCH_COUNT branches). Pruning oldest preview branch: $OLDEST_BRANCH"
              neonctl branches delete "$OLDEST_BRANCH" --project-id $NEON_PROJECT_ID || true
            fi
          fi

