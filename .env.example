# Neon Postgres
DATABASE_URL="postgresql://salesfunnel_owner:<password>@<your-neon-host>/salesfunnel?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://salesfunnel_owner:<password>@<your-neon-pooler-host>/salesfunnel?sslmode=require"

# Apollo.io
APOLLO_API_KEY=""

# Typeform
TYPEFORM_ACCESS_TOKEN=""
TYPEFORM_FORM_ID=""

# Customer.io
CUSTOMERIO_SITE_ID=""
CUSTOMERIO_API_KEY=""
CUSTOMERIO_APP_API_KEY=""

# Twilio
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Semrush
SEMRUSH_API_KEY=""

# Google Analytics / GTM
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
NEXT_PUBLIC_GTM_ID=""

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Mixpanel
NEXT_PUBLIC_MIXPANEL_TOKEN=""

# Facebook Pixel
NEXT_PUBLIC_FB_PIXEL_ID=""

# Intercom
NEXT_PUBLIC_INTERCOM_APP_ID=""

# Site
NEXT_PUBLIC_SITE_URL=""
NEXT_PUBLIC_TYPEFORM_URL=""

# Datadog — Server-side APM (dd-trace)
DD_SERVICE="dobeutech-sales-funnel"
DD_ENV="development"
DD_VERSION="0.1.0"
DD_TRACE_ENABLED="true"
DD_PROFILING_ENABLED="false"
# DD_API_KEY is only needed if sending traces directly (not via Datadog Agent)
# DD_API_KEY=""

# Datadog — Client-side RUM & Browser Logs
NEXT_PUBLIC_DD_CLIENT_TOKEN=""
NEXT_PUBLIC_DD_APPLICATION_ID=""
NEXT_PUBLIC_DD_SITE="datadoghq.com"
NEXT_PUBLIC_DD_SERVICE="dobeutech-sales-funnel"
NEXT_PUBLIC_DD_ENV="development"
NEXT_PUBLIC_DD_VERSION="0.1.0"

# Composio SDK API Key - Get from https://app.composio.dev/settings
COMPOSIO_API_KEY=

# Anthropic Claude API Key
# Option 1: Direct API key from https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=
#
# Option 2: Use Claude Code login with Max subscription (no key needed).
#   Run `claude login` locally — the SDK picks up the session automatically.
